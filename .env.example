# ════════════════════════════════════════════════════════════════
# .env.example — HealthAI Coach
# ════════════════════════════════════════════════════════════════
# 
# Instructions:
#   1. Copier ce fichier: cp .env.example .env
#   2. Remplir les valeurs appropriées
#   3. Ne JAMAIS commiter le fichier .env sur GitHub
#   4. Pour la production, créer un .env.production avec les vrais secrets
#
# Architecture: Docker Compose orchestrate postgres, api, etl, frontend, metabase
# Values ci-dessous = DEFAULTS pour la pile Docker.
#

# ─── PostgreSQL ─────────────────────────────────────────────────
# Paramètres de connexion à la base de données

POSTGRES_DB=healthai_db
POSTGRES_USER=healthai_user
POSTGRES_PASSWORD=password
POSTGRES_PORT=5432

# URL complète pour SQLAlchemy/FastAPI
DATABASE_URL=postgresql://healthai_user:password@postgres:5432/healthai_db

# ─── ETL — Extract, Transform, Load ─────────────────────────────
# Chemins pour le pipeline ETL (à adapter selon votre environnement)
#
# Docker:        /app/data/raw, /app/data/clean_bdd, etc.
# Développement: ./services/etl/data/raw, etc.

DATA_DIR=/app/data/raw                      # Où lire les datasets bruts Kaggle
CLEAN_BDD_DIR=/app/data/clean_bdd           # Où écrire les données nettoyées (BDD)
CLEAN_ML_DIR=/app/data/clean_ml             # Où écrire les données nettoyées (ML)
RAPPORT_DIR=/app/rapport                    # Où générer les rapports

# ─── API FastAPI ───────────────────────────────────────────────
# Configuration de l'API REST

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_DEBUG=true

# JWT Token
# API_SECRET_KEY est la variable lue par docker-compose.yml (SECRET_KEY de l'API)
API_SECRET_KEY=CHANGEZ_MOI_cle_secrete_tres_longue_et_aleatoire_pour_jwt
JWT_SECRET=CHANGEZ_MOI_cle_secrete_tres_longue_et_aleatoire
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# ─── MongoDB ──────────────────

MONGO_USER=healthai_mongo
MONGO_PASSWORD=mongopwd2024
MONGO_DB=healthai_exercises
MONGO_PORT=27017

# URL complète pour le micro-service Python
MONGO_URL=mongodb://healthai_mongo:mongopwd2024@mongodb:27017/healthai_exercises?authSource=admin

# ─── Metabase Dashboard ────────────────────────────────────────
# Configuration du dashboard de dataviz

METABASE_DB=metabase_db
MB_DB_TYPE=postgres
MB_DB_DBNAME=metabase_db
MB_DB_HOST=postgres
MB_DB_USER=healthai_user
MB_DB_PASS=password
MB_DB_PORT=5432
METABASE_ADMIN_EMAIL=admin@healthai.local
METABASE_ADMIN_PASSWORD=password

# ─── Frontend React ────────────────────────────────────────────
# URL de l'API disponible depuis le navigateur

VITE_API_URL=http://localhost:8000/api

# ─── Logs ────────────────────────────────────────────────────

LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG    # Pour développement avec plus de détails

# ─── MinIO — stockage objet S3-compatible ─────────────────────
# Identifiants de connexion à la console MinIO (localhost:9001)
MINIO_ROOT_USER=healthai_minio
MINIO_ROOT_PASSWORD=CHANGEZ_MOI_minio_password

# ─── Prometheus — collecte de métriques ───────────────────────
# Login : admin / mot de passe défini ici
# ATTENTION : changer le mot de passe nécessite de regénérer le hash dans monitoring/web.yml
#   python -c "import bcrypt; print(bcrypt.hashpw(b'NOUVEAU_MDP', bcrypt.gensalt()).decode())"
PROMETHEUS_ADMIN_USER=admin
PROMETHEUS_ADMIN_PASSWORD=CHANGEZ_MOI_prometheus_password

# ─── Grafana — dashboards de monitoring ───────────────────────
# Identifiants de l'interface Grafana (localhost:3003)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGEZ_MOI_grafana_password

# ─── AI API (TPRE502) + Ollama LLM ────────────────────────────
# Clé d'accès au micro-service IA (acceptée en header X-API-Key)
AI_API_KEY=dev_key

# Modèle LLM local tiré par Ollama (ex: llama3, tinyllama, mistral)
OLLAMA_MODEL=tinyllama

# Hugging Face token (optionnel — laisser vide si pas de modèle privé HF)
HF_TOKEN=

# Modèle Hugging Face pour la classification d'images (vision)
HF_MODEL=google/vit-base-patch16-224

# ─── Environnement ────────────────────────────────────────────
# Mode d'exécution

ENVIRONMENT=development
# ENVIRONMENT=production  # À utiliser en production uniquement
