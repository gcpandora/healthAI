# Normalise les fins de ligne : LF dans le repo, conversion auto selon l'OS
* text=auto

# Force LF pour les fichiers qui doivent rester LF (scripts, configs Linux)
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
Dockerfile text eol=lf
*.py text eol=lf
*.sql text eol=lf

# Fichiers binaires — pas de conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.whl binary
